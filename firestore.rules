rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // mail_logs is written only by Cloud Functions via the Admin SDK,
    // which bypasses these rules. Deny all direct client access.
    match /mail_logs/{logId} {
      allow read, write: if false;
    }

    // payout_logs (토스 지급대행 감사 로그) — 동일하게 Admin SDK 전용.
    match /payout_logs/{logId} {
      allow read, write: if false;
    }
  }
}
