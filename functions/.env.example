# SMTP relay (set via `firebase functions:secrets:set SMTP_HOST` / `SMTP_USER` / `SMTP_PASS` for deploy)
# 어떤 SMTP 릴레이든 사용 가능 (AWS SES, SMTP2GO, Brevo 등). 587=STARTTLS, 465=TLS.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Sender address (릴레이에서 인증된 발신 도메인/주소여야 함)
MAIL_FROM_ADDRESS=contact@cho-fam.com

# JSON map of issued API keys to caller service name.
# Each calling service (game server, manager webpage, etc.) gets its own key.
# Set via `firebase functions:secrets:set MAIL_API_KEYS` for deploy.
MAIL_API_KEYS={"replace-with-liv-ay-key":"liv-ay","replace-with-admin-key":"cho-fam-admin"}

# Comma-separated list of source names allowed to call admin endpoints (/mail/logs, resend)
MAIL_ADMIN_SOURCES=cho-fam-admin

# ── Toss Payments 지급대행 (payout) ─────────────────────────────
# Set via `firebase functions:secrets:set TOSS_SECRET_KEY` / `TOSS_SECURITY_KEY` for deploy.
# 시크릿 키: 토스 개발자센터 API 키. 보안 키: 지급대행 JWE 암호화용(별도 발급).
TOSS_SECRET_KEY=
TOSS_SECURITY_KEY=

# Comma-separated list of source names allowed to call /payout endpoints
PAYOUT_SOURCES=liv-ay
