# SendGrid API key (set via `firebase functions:secrets:set SENDGRID_API_KEY` for deploy)
SENDGRID_API_KEY=

# Verified sender address in SendGrid
MAIL_FROM_ADDRESS=noreply@chofam-home.web.app

# JSON map of issued API keys to caller service name.
# Each calling service (game server, manager webpage, etc.) gets its own key.
# Set via `firebase functions:secrets:set MAIL_API_KEYS` for deploy.
MAIL_API_KEYS={"replace-with-liv-ay-key":"liv-ay","replace-with-admin-key":"chofam-admin"}

# Comma-separated list of source names allowed to call admin endpoints (/mail/logs, resend)
MAIL_ADMIN_SOURCES=chofam-admin
