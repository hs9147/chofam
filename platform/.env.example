# 1차(중소규모)=small / 2차(대기업)=enterprise
PAAS_TIER=small

# --- 설치 빌드옵션 ---
# 기능 모듈 선택 (core는 항상 켜짐): deploy, workspace, mail, payment
PAAS_FEATURES=deploy,workspace,mail,payment
# 운영환경 OS: auto(감지) | linux | macos | windows
PAAS_HOST_OS=auto
# GPU 미지원 OS에서 GPU 컨테이너 강제 허용
PAAS_FORCE_GPU=false

# --- mail 모듈 (CHO-FAM 메일 API 알림) ---
PAAS_MAIL_API_URL=
PAAS_MAIL_API_KEY=
PAAS_MAIL_ALERT_TO=
PAAS_MAIL_TEMPLATE_ID=

# --- payment 모듈 (토스페이먼츠 결제 수납) ---
PAAS_TOSS_SECRET_KEY=

PAAS_BASE_DOMAIN=deploy.example.com
PAAS_DATABASE_URL=sqlite:///./paas.db
PAAS_ADMIN_API_KEY=
PAAS_FERNET_KEY=
PAAS_WEBHOOK_SECRET=
# 프로젝트 git 체크아웃(코드 확인·채팅·빌드가 공유) / 빌드 로그 저장 위치.
# 기본은 platform/ 기준 상대경로 — 그 위치에 쓰기 권한이 없거나(예: Windows에서
# 플랫폼을 실행하는 계정이 C: 드라이브에 못 씀) 다른 드라이브에 두고 싶으면 절대경로로
# 바꿀 것(예: D:\paas-data\workspaces). 프로젝트별 하위 폴더명은 프로젝트 이름 그대로다
# (PAAS_WORK_DIR=D:\paas-data\workspaces 인 프로젝트 "test"의 체크아웃 경로는
# D:\paas-data\workspaces\test).
PAAS_WORK_DIR=./data/workspaces
PAAS_BUILD_LOG_DIR=./data/build-logs
# 사내 Git 서버(infra/gitea/ 배포 후 실제 주소) — 설정 시 콘솔에 "Git" 메뉴가 표시됨
PAAS_GITEA_URL=
# 조직/리포 자동 생성용 Gitea API 토큰 (Site Administration → Applications에서 발급)
PAAS_GITEA_API_TOKEN=
# 기본값 true — 프로젝트 git_url이 위 PAAS_GITEA_URL 호스트가 아니면 등록 자체를 거부
# (PAAS_GITEA_URL 미설정 시에는 등록 자체가 503). 외부 git 호스트를 허용하려면 false로.
PAAS_GIT_INTERNAL_ONLY=true

# --- zip/폴더 업로드로 프로젝트 등록 (services/upload.py) ---
PAAS_UPLOAD_MAX_ZIP_MB=200
PAAS_UPLOAD_MAX_UNCOMPRESSED_MB=500
PAAS_UPLOAD_MAX_FILES=5000
PAAS_UPLOAD_MAX_COMPRESSION_RATIO=100
# 웹훅 자동 등록용 플랫폼 공개 주소 (예: https://paas.example.com). 비우면
# 조직/업로드로 만든 리포에 웹훅을 자동 등록하지 않고 수동 설정으로 대체된다.
PAAS_PLATFORM_PUBLIC_URL=
# 외부 API 디렉터리 검색(모듈 레지스트리 → external_api 자동 추가)이 조회하는 머신리더블
# OpenAPI 목록. 기본은 apis.guru 공개 목록. 폐쇄망은 사내 미러 URL로 교체.
PAAS_API_DIRECTORY_URL=https://api.apis.guru/v2/list.json

# --- 콘솔 자기 배포 (옵트인, services/self_deploy.py) ---
# true면 백엔드 기동 시 platform/console/을 일반 react Project(source_subdir 사용)로
# 등록해 기존 배포 파이프라인으로 최초 1회 배포한다(기본 꺼짐 — 꺼져 있으면 지금처럼
# /console에 정적 마운트). Docker 데몬 접근 필요 + 최초 배포 시간 동안 콘솔 접근 불가.
PAAS_SELF_DEPLOY_CONSOLE=false
PAAS_SELF_DEPLOY_CONSOLE_GIT_URL=
PAAS_SELF_DEPLOY_CONSOLE_BRANCH=main

# --- 1차(small) 실행 런타임 / 리버스프록시 백엔드 선택 ---
# 실행 런타임: docker(기본) | windows_service(Docker 없이 nssm으로 Windows Service 등록)
PAAS_RUNTIME_BACKEND=docker
# 리버스프록시: caddy(기본) | iis | apache
PAAS_PROXY_BACKEND=caddy
# windows_service 런타임 전용 — nssm(Non-Sucking Service Manager) 실행 파일 경로
PAAS_NSSM_PATH=nssm
# iis 프록시 전용 — 사이트별 web.config 물리 경로 루트 / appcmd.exe 경로
PAAS_IIS_SITES_ROOT=./data/iis-sites
PAAS_IIS_APPCMD_PATH=C:\Windows\System32\inetsrv\appcmd.exe
# apache 프록시 전용 — VirtualHost 설정 디렉토리 / 반영 명령
PAAS_APACHE_SITES_DIR=./data/apache-sites
PAAS_APACHE_RELOAD_CMD=apachectl graceful

# enterprise 전용
PAAS_K8S_NAMESPACE=paas-apps
PAAS_K8S_REGISTRY=
PAAS_K8S_INGRESS_CLASS=traefik
PAAS_K8S_CLUSTER_ISSUER=letsencrypt
